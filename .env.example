# 🚀 STUDYHUB - Environment Configuration
# This file serves as a template for your local .env file.
# Copy this file to .env and fill in your credentials.

# ─── SERVER CONFIG ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE CONFIG ────────────────────────────────────────
# PostgreSQL (Recommended Default)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=notes_platform
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# MySQL (Alternative support)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=notes_platform
# DB_USER=root
# DB_PASSWORD=your_mysql_password

# ─── AUTH & SECURITY ────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# ─── AI & INTELLIGENCE ──────────────────────────────────────
# Required for smart PDF summarization and advanced insights
GEMINI_API_KEY=your_google_gemini_api_key_here

# ─── CACHING & PERFORMANCE ──────────────────────────────────
# Required for rate-limiting and performance optimizations
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── FILE UPLOAD CONFIG ─────────────────────────────────────
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# AWS S3 (Optional - for cloud storage in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ─── EMAIL CONFIGURATION ────────────────────────────────────
# Used for verification, password resets, and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=viphacker.100.org@gmail.com
SMTP_PASSWORD=your_email_app_password
EMAIL_FROM=viphacker.100.org@gmail.com

# ─── REAL-TIME & WEBSOCKET ──────────────────────────────────
SOCKET_CORS_ORIGIN=http://localhost:5173
